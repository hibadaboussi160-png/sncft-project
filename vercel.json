{
    "version": 2,
    "builds": [
        {
            "src": "public/index.php",
            "use": "@vercel/php",
            "config": { 
                "installCommand": "composer install --no-dev --no-scripts --ignore-platform-reqs" 
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/public/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "VERCEL_PHP_VERSION": "8.2"
    }
}